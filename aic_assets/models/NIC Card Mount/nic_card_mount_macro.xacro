<?xml version="1.0" ?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">

  <xacro:macro name="nic_card_mount" params="prefix pose">
    <gazebo>
      <include>
        <name>${prefix}</name>
        <uri>package://aic_assets/models/NIC Card Mount</uri>
        <pose>${pose}</pose>
      </include>
    </gazebo>
  </xacro:macro>

</robot>
